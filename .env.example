# Claude API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# The ID from your Tiller Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
TILLER_SPREADSHEET_ID=your_google_sheet_id_here

# Name of the sheet tab that holds transactions (default: Transactions)
TILLER_SHEET_NAME=Transactions
